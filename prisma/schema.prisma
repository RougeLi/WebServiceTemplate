generator client {
  provider = "prisma-client-js"
}

datasource db_line_bot {
  provider = "postgresql"
  url      = env("LINE_BOT_DATABASE_URL")
}

model WebhookRequest {
  id          Int      @id @default(autoincrement()) @map("id")
  destination String   @map("destination") @db_line_bot.VarChar(100)
  receivedAt  DateTime @default(now()) @map("received_at") @db_line_bot.Timestamptz(6)

  events WebhookEvent[]

  @@map("webhook_requests")
}

model WebhookEvent {
  id              Int      @id @default(autoincrement()) @map("id")
  requestId       Int      @map("request_id")
  type            String   @map("type") @db_line_bot.VarChar(50)
  mode            String   @map("mode") @db_line_bot.VarChar(10)
  timestamp       BigInt   @map("timestamp")
  source          Json     @map("source")
  webhookEventId  String   @map("webhook_event_id") @db_line_bot.VarChar(100)
  deliveryContext Json     @map("delivery_context")
  createdAt       DateTime @default(now()) @map("created_at") @db_line_bot.Timestamptz(6)

  request WebhookRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  messageEvent           MessageEvent?
  unsendEvent            UnsendEvent?
  followEvent            FollowEvent?
  // unfollowEvent                    UnfollowEvent?
  joinEvent              JoinEvent?
  // leaveEvent                       LeaveEvent?
  memberJoinEvent        MemberJoinEvent?
  memberLeaveEvent       MemberLeaveEvent?
  postbackEvent          PostbackEvent?
  videoPlayCompleteEvent VideoPlayCompleteEvent?
  beaconEvent            BeaconEvent?
  accountLinkEvent       AccountLinkEvent?

  @@index([requestId])
  @@index([type])
  @@map("webhook_events")
}

model MessageEvent {
  id          Int      @id @default(autoincrement()) @map("id")
  eventId     Int      @unique @map("event_id")
  messageId   String   @map("message_id") @db_line_bot.VarChar(50)
  messageType String   @map("message_type") @db_line_bot.VarChar(20)
  message     Json     @map("message")
  createdAt   DateTime @default(now()) @map("created_at") @db_line_bot.Timestamptz(6)

  event WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("message_events")
}

model UnsendEvent {
  id        Int      @id @default(autoincrement()) @map("id")
  eventId   Int      @unique @map("event_id")
  detail    Json     @map("detail")
  createdAt DateTime @default(now()) @map("created_at") @db_line_bot.Timestamptz(6)

  event WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("unsend_events")
}

model FollowEvent {
  id        Int      @id @default(autoincrement()) @map("id")
