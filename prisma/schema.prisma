  detail    Json     @map("detail")
  createdAt DateTime @default(now()) @map("created_at") @db_line_bot.Timestamptz(6)

  event WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("follow_events")
}

